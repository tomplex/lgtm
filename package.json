{
  "name": "lgtm",
  "version": "0.1.0",
  "description": "Web-based review UI for collaborating with Claude Code",
  "private": true,
  "type": "module",
  "scripts": {
    "build:server": "tsc -p server/tsconfig.json",
    "build:frontend": "tsc -p frontend/tsconfig.json && vite build",
    "build": "npm run build:server && npm run build:frontend",
    "dev": "tsx watch server/server.ts",
    "dev:frontend": "vite",
    "dev:all": "concurrently -n server,frontend -c blue,green \"npm run dev -- --repo . --port 9900\" \"REVIEW_PORT=9900 npm run dev:frontend\"",
    "start": "node dist/server/server.js",
    "test": "npm run test:frontend && npm run test:server",
    "test:frontend": "vitest run",
    "test:frontend:watch": "vitest",
    "test:server": "vitest run --config vitest.config.server.ts",
    "test:server:watch": "vitest --config vitest.config.server.ts",
    "lint": "eslint server/ frontend/src/",
    "lint:server": "eslint server/",
    "lint:frontend": "eslint frontend/src/",
    "format": "prettier --write frontend/src/",
    "format:check": "prettier --check frontend/src/"
  },
  "bin": {
    "lgtm": "dist/server/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0",
    "express": "^5.1.0",
    "highlight.js": "^11.9.0",
    "marked": "^12.0.1",
    "open": "^10.1.0",
    "solid-js": "^1.9.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "^4.1.2"
  }
}
